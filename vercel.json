{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/curtaincleaningkl.html" },
    { "source": "/contact", "destination": "/curtaincleaningkl.html" },
    { "source": "/pricing", "destination": "/curtaincleaningkl.html" },
    { "source": "/services", "destination": "/curtaincleaningkl.html" },
    { "source": "/areas",    "destination": "/curtaincleaningkl.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
